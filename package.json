{
  "name": "monkey-browser-ai",
  "version": "0.1.0",
  "description": "Chrome extension that turns natural-language tickets into step-by-step, confirm-before-act browser automation driven by Gemini.",
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@types/chrome": "^0.1.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
